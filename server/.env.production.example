# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://user:password@host:5432/dcrm_prod

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Générer : openssl rand -hex 32
JWT_SECRET=CHANGEME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGEME_openssl_rand_hex_32

# ─── Chiffrement des tokens sensibles (AES-256-GCM) ─────────────────────────
# Générer : openssl rand -hex 32
TOKEN_ENC_KEY=CHANGEME_openssl_rand_hex_32

# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────
# 1. Créer un projet sur https://console.cloud.google.com/
# 2. Activer l'API "Google Calendar" (vague G2) et "People API" (facultatif)
# 3. Créer des identifiants OAuth 2.0 → Application Web
# 4. Ajouter les URI de redirection autorisés :
#    https://votre-domaine.fr/api/auth/google/callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://votre-domaine.fr/api/auth/google/callback

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://votre-domaine.fr

# ─── VoIP ────────────────────────────────────────────────────────────────────
VOIP_WEBHOOK_SECRET=CHANGEME_openssl_rand_hex_32

# ─── Mailer (optionnel) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.votre-fournisseur.fr
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@votre-domaine.fr

NODE_ENV=production
PORT=3001
