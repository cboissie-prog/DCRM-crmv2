# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_PROVIDER="postgresql"
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://crm_user:MOT_DE_PASSE@localhost:5432/crm_prod"

# ── JWT — générer avec : node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
# ou : openssl rand -hex 64
JWT_SECRET="REMPLACER_PAR_64_OCTETS_ALEATOIRES"
JWT_REFRESH_SECRET="REMPLACER_PAR_64_OCTETS_ALEATOIRES_DIFFERENT"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL="https://dcrm.dcb-technologies.fr"
APP_URL="https://dcrm.dcb-technologies.fr"

# ── SMTP ───────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.dcb-technologies.fr
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@dcb-technologies.fr
SMTP_PASS=MOT_DE_PASSE_SMTP
SMTP_FROM=MonCRM <noreply@dcb-technologies.fr>
